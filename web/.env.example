# Auth.js / Google OAuth
AUTH_SECRET=replace-with-long-random-secret
AUTH_GOOGLE_ID=replace-with-google-client-id
AUTH_GOOGLE_SECRET=replace-with-google-client-secret
AUTH_URL=http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Demo + support
NEXT_PUBLIC_APP_VERSION=2026.4-demo
NEXT_PUBLIC_SUPPORT_EMAIL=team@example.com
NEXT_PUBLIC_MAPBOX_TOKEN=

# Optional realtime backends (demo mode works without these)
NEXT_PUBLIC_SOCKET_URL=
NEXT_PUBLIC_VERCEL_SYNC_ENDPOINT=
NEXT_PUBLIC_VERCEL_LISTENER_URL=
